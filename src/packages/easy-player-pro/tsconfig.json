{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "declaration": true,
    "outDir": "./lib",
    "declarationDir": "./lib/types",
    "strict": true,
    "lib": [
      "es2016",
      "dom"
    ],
    "typeRoots": [
      "src/types",
      "node_modules/@types"
    ],
    "esModuleInterop": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "tests"
  ]
}
